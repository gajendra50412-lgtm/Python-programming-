# Q6. Simple Calculator Function

print("\n" + "=" * 50)
print("Q6. Simple Calculator Function")
print("=" * 50)

def addition(a, b):       return a + b
def subtraction(a, b):    return a - b
def multiplication(a, b): return a * b
def division(a, b):
    if b == 0:
        return "Error: Division by zero"
    return a / b

# Demo (replace input() with fixed values to allow non-interactive run)
a, b = 10, 4
print(f"Numbers: {a} and {b}")
print("Addition      :", addition(a, b))
print("Subtraction   :", subtraction(a, b))
print("Multiplication:", multiplication(a, b))
print("Division      :", division(a, b))
